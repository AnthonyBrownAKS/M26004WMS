@startuml
title 客商数据管理模块

start

:用户进入客商模块;

if (操作类型) then (CRUD)
  :新增 / 修改 / 删除 / 查询;
  :Controller → Service → DB;
  :返回结果;

elseif (导入Excel)
  :上传Excel;
  :EasyExcel解析;
  :DTO → Entity;

  if (数据已存在?) then (是)
    :更新数据;
  else (否)
    :新增数据;
  endif

  :批量写入数据库;
  :返回导入结果;

elseif (导出Excel)
  :查询全部数据;
  :Entity → Excel;
  :生成xlsx文件;
  :下载;

endif

stop
@enduml